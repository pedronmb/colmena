.env
.env.*
!.env.example

# Composer (por si se añade más adelante)
/vendor/

# Logs y cachés comunes
*.log
.phpunit.result.cache

# SO y editores
.DS_Store
Thumbs.db
desktop.ini

# IDEs (descomenta si no quieres versionar ajustes locales)
